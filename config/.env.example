# OpenAI API key (required) - used by all CrewAI agents
OPENAI_API_KEY=sk-...

# Gemini API key (optional) - used to generate one cover image per blog post
# Cost: ~$0.03 per image. Set ENABLE_IMAGE_GEN=false to disable.
GEMINI_API_KEY=AIzaSy...
ENABLE_IMAGE_GEN=true

# Telegram (optional) - notifications when new blogs are published
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# YouTube cookies (optional but STRONGLY RECOMMENDED for reliable transcript
# fetching). If YouTube blocks your IP, export cookies from your logged-in
# browser session using an extension like "Get cookies.txt LOCALLY" (Chrome)
# or "cookies.txt" (Firefox), save to cookies.txt (gitignored!), and set:
# YOUTUBE_COOKIES_PATH=/absolute/path/to/cookies.txt

# Disable telemetry from chromadb / posthog (used by CrewAI)
CHROMA_TELEMETRY_DISABLED=1
POSTHOG_DISABLED=1
